---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ResourceList } from '../../components/resources/ResourceList.tsx';
---

<BaseLayout title="Resources">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Resource Hub</h1>
      <p className="mt-2 text-gray-600 dark:text-gray-400">
        Browse curated mental health resources, emergency contacts, counseling services, and
        self-help materials.
      </p>
    </div>
    <ResourceList client:load />
  </div>
</BaseLayout>
