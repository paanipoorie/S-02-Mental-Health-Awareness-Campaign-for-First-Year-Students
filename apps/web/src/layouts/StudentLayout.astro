---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
  description?: string;
  anonymousDisplayName?: string;
}

const {
  title = 'Student Dashboard | Anonymous Peer Support',
  description = 'Confidential peer support dashboard for first-year students.',
  anonymousDisplayName = 'Anonymous Student',
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  currentRole="STUDENT"
  displayName={anonymousDisplayName}
>
  <div class="space-y-6">
    <div class="flex items-center justify-between border-b border-slate-800/80 pb-4">
      <div>
        <h1
          class="bg-gradient-to-r from-teal-300 to-indigo-300 bg-clip-text text-2xl font-bold text-transparent"
        >
          Student Portal
        </h1>
        <p class="text-xs text-slate-400">
          Connected anonymously as <span class="font-semibold text-teal-300"
            >{anonymousDisplayName}</span
          >
        </p>
      </div>
    </div>
    <slot />
  </div>
</BaseLayout>
