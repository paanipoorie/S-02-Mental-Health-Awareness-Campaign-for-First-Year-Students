---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
  description?: string;
  mentorName?: string;
  isVerified?: boolean;
}

const {
  title = 'Mentor Dashboard | Peer Support',
  description = 'Mentor hub for managing active chats, hosting workshops, and supporting students.',
  mentorName = 'Peer Mentor',
  isVerified = true,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  currentRole="MENTOR"
  displayName={mentorName}
  isVerified={isVerified}
>
  <div class="space-y-6">
    <div class="flex items-center justify-between border-b border-slate-800/80 pb-4">
      <div>
        <h1 class="text-2xl font-bold bg-gradient-to-r from-purple-300 to-indigo-300 bg-clip-text text-transparent">
          Mentor Portal
        </h1>
        <p class="text-xs text-slate-400">Welcome, <span class="text-purple-300 font-semibold">{mentorName}</span></p>
      </div>
    </div>
    <slot />
  </div>
</BaseLayout>
