---
interface Props {
  emotion: string;
  urgency?: string;
  size?: 'sm' | 'md' | 'lg';
  showUrgency?: boolean;
}
---

{/* Import emotion constants */}
<script is:inline>
  import { EMOTIONS, URGENCY_LEVELS } from '@lib/emotionConstants';

  const { emotion, urgency, size = 'md', showUrgency = true } = Astro.props;

  const emotionConfig = EMOTIONS.find(e => e.type === emotion) || EMOTIONS[0];
  const urgencyConfig = urgency
    ? URGENCY_LEVELS.find(u => u.level === urgency) || URGENCY_LEVELS[0]
    : null;

  const sizeClasses = {
    sm: 'px-2 py-1 text-xs',
    md: 'px-3 py-1.5 text-sm',
    lg: 'px-4 py-2 text-base',
  };
</script>

<div
  class="emotion-badge"
  style="--emotion-color: {emotionConfig.color}; --emotion-bg: {emotionConfig.bg}; --emotion-border: {emotionConfig.border};"
>
  <span
    class="{sizeClasses[size]} inline-flex items-center gap-1.5 rounded-full border-2 font-medium"
    style="background: var(--emotion-bg); border-color: var(--emotion-border); color: var(--emotion-color);"
  >
    <span>{emotionConfig.emoji}</span>
    <span>{emotionConfig.label}</span>
  </span>

  {
    showUrgency && urgencyConfig && (
      <span
        class="{sizeClasses[size]} ml-2 inline-flex items-center gap-1 rounded-full border-2 font-medium"
        style="background: {urgencyConfig.bg}; border-color: {urgencyConfig.color}; color: {urgencyConfig.color};"
      >
        <span>{urgencyConfig.icon}</span>
        <span>{urgencyConfig.label}</span>
      </span>
    )
  }
</div>

<style is:global>
  .emotion-badge {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }
</style>
