---
interface Props {
  isVerified?: boolean;
  size?: 'sm' | 'md' | 'lg';
  className?: string;
}
---
const { isVerified = true, size = 'md', className = '' } = Astro.props;

const sizeClasses = {
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
};

const color = isVerified ? 'text-blue-600 dark:text-blue-400' : 'text-gray-400 dark:text-gray-500';
const classList = 'inline-flex shrink-0 ' + sizeClasses[size] + ' ' + color + ' ' + className;
---

<svg
  class={classList}
  fill="currentColor"
  viewBox="0 0 24 24"
  aria-label={isVerified ? "Verified Mentor" : "Unverified"}
  role="img"
>
  <path
    fill-rule="evenodd"
    d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"
    clip-rule="evenodd"
  ></path>
</svg>

<style>
  :host {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
</style>