---
interface Props {
  role?: string;
  isVerified?: boolean;
  className?: string;
}

const { role = 'STUDENT', isVerified = false, className = '' } = Astro.props;

let badgeText = 'Student';
let badgeStyles = 'bg-teal-500/10 text-teal-400 border-teal-500/30';

if (role === 'MENTOR') {
  badgeText = isVerified ? 'Verified Mentor' : 'Mentor';
  badgeStyles = isVerified
    ? 'bg-purple-500/15 text-purple-300 border-purple-500/40 shadow-sm shadow-purple-500/20'
    : 'bg-indigo-500/10 text-indigo-300 border-indigo-500/30';
} else if (role === 'ADMIN') {
  badgeText = 'Admin';
  badgeStyles = 'bg-rose-500/10 text-rose-300 border-rose-500/30';
}
---

<span
  class={`inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold border transition-all ${badgeStyles} ${className}`}
>
  {role === 'MENTOR' && isVerified && (
    <svg class="w-3 h-3 text-purple-400 fill-current" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
    </svg>
  )}
  {badgeText}
</span>
