---
import RoleBadge from './RoleBadge.astro';

interface Props {
  currentRole?: 'STUDENT' | 'MENTOR' | 'ADMIN' | null;
  displayName?: string;
  isVerified?: boolean;
}

const { currentRole = null, displayName = '', isVerified = false } = Astro.props;
---

<header
  class="sticky top-0 z-50 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur-md transition-all"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo & Brand -->
      <div class="flex items-center gap-3">
        <a href="/" class="group flex items-center gap-2">
          <div
            class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-tr from-teal-500 to-indigo-600 shadow-lg shadow-teal-500/20 transition-transform group-hover:scale-105"
          >
            <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
              ></path>
            </svg>
          </div>
          <div class="flex flex-col">
            <span
              class="bg-gradient-to-r from-teal-300 via-indigo-200 to-purple-300 bg-clip-text text-base font-bold text-transparent"
            >
              Campus Sanctuary
            </span>
            <span class="text-[10px] font-medium uppercase tracking-wider text-slate-400"
              >Anonymous Peer Support</span
            >
          </div>
        </a>
      </div>

      <!-- Navigation Links based on role -->
      <nav class="hidden items-center gap-1 md:flex">
        {
          currentRole === 'STUDENT' && (
            <>
              <a
                href="/dashboard"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Dashboard
              </a>
              <a
                href="/discussions"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Discussions
              </a>
              <a
                href="/chat"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Peer Support Chat
              </a>
              <a
                href="/workshops"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Workshops
              </a>
              <a
                href="/resources"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Resources
              </a>
            </>
          )
        }

        {
          currentRole === 'MENTOR' && (
            <>
              <a
                href="/mentor/dashboard"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Mentor Dashboard
              </a>
              <a
                href="/mentor/chats"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Active Chats
              </a>
              <a
                href="/mentor/workshops"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Hosted Workshops
              </a>
              <a
                href="/resources"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Resources
              </a>
            </>
          )
        }

        {
          currentRole === 'ADMIN' && (
            <>
              <a
                href="/admin/dashboard"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Admin Dashboard
              </a>
              <a
                href="/admin/mentors"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Verify Mentors
              </a>
              <a
                href="/resources"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Manage Resources
              </a>
            </>
          )
        }

        {
          !currentRole && (
            <>
              <a
                href="/resources"
                class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800/60 hover:text-white"
              >
                Resources
              </a>
            </>
          )
        }
      </nav>

      <!-- User Action / Auth CTA -->
      <div class="flex items-center gap-3">
        {
          currentRole ? (
            <div class="flex items-center gap-3 rounded-full border border-slate-800 bg-slate-900/80 px-3 py-1.5">
              <RoleBadge role={currentRole} isVerified={isVerified} />
              {displayName && (
                <span class="max-w-[140px] truncate text-xs font-semibold text-slate-200">
                  {displayName}
                </span>
              )}
              <button
                id="logout-btn"
                class="ml-1 text-xs font-medium text-slate-400 transition-colors hover:text-rose-400"
                title="Sign Out"
              >
                Logout
              </button>
            </div>
          ) : (
            <div class="flex items-center gap-2">
              <a
                href="/login"
                class="rounded-xl border border-slate-800 px-4 py-2 text-xs font-semibold text-slate-300 transition-all hover:bg-slate-800/60 hover:text-white"
              >
                Sign In
              </a>
              <a
                href="/register"
                class="rounded-xl bg-gradient-to-r from-teal-500 to-indigo-600 px-4 py-2 text-xs font-semibold text-white shadow-md shadow-teal-500/20 transition-all hover:from-teal-400 hover:to-indigo-500"
              >
                Get Started
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</header>

<script>
  import { clearAuthUser } from '../../stores/authStore';

  const logoutBtn = document.getElementById('logout-btn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', async () => {
      try {
        await fetch('http://localhost:3000/api/auth/logout', { method: 'POST' });
      } catch (err) {
        console.error('Logout error:', err);
      } finally {
        clearAuthUser();
        window.location.href = '/login';
      }
    });
  }
</script>
